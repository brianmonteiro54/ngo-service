# =============================================================================
# .dockerignore - ngo-service (Python)
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Documentação
README.md
*.md
LICENSE

# Variáveis de ambiente (NUNCA dentro da imagem)
.env
.env.local
.env.*.local

# Python - caches e bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Virtualenvs
venv/
.venv/
env/
ENV/
*.egg-info/

# Diretórios de build/cache
build/
dist/

# Arquivos de teste (não copiados para a imagem)
tests/
test_*.py
*_test.py

# Arquivos temporários
*.tmp
*.log
*.swp
*.swo
*~

# IDE / Editor
.vscode/
.idea/
*.iml
.DS_Store

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
